menu "AWP Edge Node Configuration"

    config AWP_WIFI_SSID
        string "WiFi SSID"
        default "YOUR_SSID"
        help
            WiFi network name.

    config AWP_WIFI_PASSWORD
        string "WiFi Password"
        default "YOUR_PASSWORD"
        help
            WiFi network password.

    config AWP_UPSTREAM_HOST
        string "Upstream node IP address"
        default "192.168.1.100"
        help
            IP address of the upstream AIOS CORE/NODE to connect to.

    config AWP_UPSTREAM_PORT
        int "Upstream node port"
        default 9000
        help
            AWP port of the upstream node.

    config AWP_LISTEN_PORT
        int "Local AWP listen port"
        default 9200
        help
            Port this edge node listens on for local connections.

    config AWP_NODE_NAME
        string "Node name"
        default "esp32-edge"
        help
            Human-readable name for this edge node.

    config AWP_HDC_CACHE_CAPACITY
        int "HDC cache capacity (vectors)"
        default 64
        help
            Number of HDC vectors to cache locally. Limited by RAM.

    config AWP_SENSOR_POLL_INTERVAL_MS
        int "Sensor poll interval (ms)"
        default 5000
        help
            How often to read sensors and report telemetry.

    config AWP_HEARTBEAT_INTERVAL_MS
        int "Heartbeat interval (ms)"
        default 10000
        help
            How often to send PING to upstream node.

    config AWP_PSK
        string "Pre-shared key (hex, minimum 16 bytes / 32 hex chars)"
        default ""
        help
            Hex-encoded pre-shared key. REQUIRED for secure handshake.

            The PSK is mixed into session-key derivation (KDF(ss || psk)).
            An attacker who does not know the PSK cannot recover the
            session key even with full network control, because the
            ML-KEM handshake alone does not authenticate the upstream.
            A formal audit (docs/audits/formal/REPORT.md, finding F-01)
            showed the protocol reduces to unauthenticated ephemeral KEX
            without a secret PSK.

            Minimum 16 bytes (32 hex chars) is enforced at boot.
            Up to 64 bytes (128 hex chars) supported.

            Can also be provisioned via NVS key "awp_psk" in namespace
            "awp_crypto". NVS provisioning takes priority over Kconfig.

    config AWP_REQUIRE_PSK
        bool "Require PSK at boot (recommended)"
        default y
        help
            When enabled, the device refuses to start without a valid PSK.
            Disabling is only for bring-up and testing against a trusted,
            isolated network; production deployments MUST keep this enabled.

    config AWP_RECONNECT_BACKOFF_MAX_MS
        int "Max reconnect backoff (ms)"
        default 60000
        help
            Maximum delay between reconnection attempts (exponential backoff).

    config AWP_INCLUDE_SELF_TESTS
        bool "Compile and run crypto self-tests on boot"
        default y
        help
            When enabled, 14 crypto self-tests (BLAKE3, XChaCha20-Poly1305,
            ML-KEM-768, replay window, frame roundtrip, tamper detection)
            run at boot and halt the device on failure.

            Disable for production images where the tests have already
            been validated on the exact firmware revision being shipped —
            this strips ~30 KB of test code and vectors from the image
            and reduces attack surface (audit F-08). Build-time validation
            must be performed on an image with this option enabled.

endmenu
